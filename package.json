{
  "name": "nexterm",
  "version": "1.2.1-BETA",
  "main": "server/index.js",
  "bin": {
    "ntctl": "server/cli/index.js"
  },
  "repository": "https://github.com/gnmyt/Nexterm.git",
  "author": "Mathias Wagner",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/openai": "^4.0.14",
    "@ai-sdk/openai-compatible": "^3.0.7",
    "@inquirer/password": "^5.1.1",
    "@simplewebauthn/server": "^13.3.2",
    "ai": "^7.0.28",
    "archiver": "^8.0.0",
    "bcrypt": "^6.0.0",
    "commander": "^15.0.0",
    "decompress": "^4.2.1",
    "express": "^5.2.1",
    "express-jsdoc-swagger": "^1.8.0",
    "express-rate-limit": "^8.5.2",
    "express-ws": "^5.0.2",
    "flatbuffers": "^25.9.23",
    "joi": "^18.2.3",
    "js-yaml": "^5.2.1",
    "ldapts": "^9.0.0",
    "mysql2": "^3.23.0",
    "openid-client": "^6.8.4",
    "selfsigned": "^5.5.0",
    "sequelize": "^6.37.8",
    "speakeasy": "^2.0.0",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.1",
    "webdav": "^5.10.0",
    "winston": "^3.19.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "nodemon": "^3.1.11",
    "vitepress": "^1.6.4",
    "vitepress-openapi": "^0.2.1"
  },
  "scripts": {
    "dev:server": "nodemon --ignore docs --ignore vendor --ignore client --ignore mobile --ignore data server/index.js",
    "dev:client": "cd client && yarn run dev",
    "dev:guacd": "./scripts/build-guacd.sh",
    "dev:engine": "./scripts/build-engine.sh",
    "dev": "LOCAL_ENGINE_TOKEN=${LOCAL_ENGINE_TOKEN:-nexterm-dev-local-engine-token} concurrently --kill-others-on-fail \"yarn dev:server\" \"yarn dev:client -- --host\" \"yarn schema:watch\" \"yarn dev:engine\"",
    "docs:openapi": "node scripts/generate-openapi.js",
    "schema:generate": "flatc --ts --ts-flat-files -o server/lib/generated schema/control_plane.fbs schema/sftp_protocol.fbs && esbuild server/lib/generated/nexterm/control-plane.ts --bundle --format=cjs --outfile=server/lib/generated/control_plane_generated.js --allow-overwrite --platform=node --external:flatbuffers && esbuild server/lib/generated/nexterm/sftp-protocol.ts --bundle --format=cjs --outfile=server/lib/generated/sftp_protocol_generated.js --allow-overwrite --platform=node --external:flatbuffers && rm -rf server/lib/generated/nexterm",
    "schema:watch": "nodemon --watch schema -e fbs --exec 'yarn schema:generate'",
    "docs:dev": "yarn docs:openapi && vitepress dev docs",
    "docs:build": "yarn docs:openapi && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build:sea": "./scripts/build-sea.sh"
  }
}
